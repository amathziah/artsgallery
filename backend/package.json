{
  "name": "saat-saath-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "install-client": "cd ../frontend && npm install",
    "build-client": "cd ../frontend && npm run build",
    "heroku-postbuild": "npm run install-client && npm run build-client",
    "build": "npm run install-client && npm run build-client && npm run start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
